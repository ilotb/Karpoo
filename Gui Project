   Flag = "AutoBuyAll",

   Callback = function(Value)
      getgenv().AutoBuy = Value

      if Value then
         task.spawn(function()
            local remote = game:GetService("ReplicatedStorage")
            .Remotes.MerchantRemotes.PurchaseMerchantItem

            local items = {
                "Boss Key","Dungeon Key","Race Reroll","Rush Key",
                "Passive Shard","Trait Reroll","Clan Reroll","Haki Color Reroll"
            }

            while getgenv().AutoBuy do
                for _, item in ipairs(items) do
