-- 📌 ตัวละคร
local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")

player.CharacterAdded:Connect(function(newChar)
    char = newChar
    hrp = char:WaitForChild("HumanoidRootPart")
end)

local npcFolder = workspace:WaitForChild("NPCs")
local RunService = game:GetService("RunService")

local currentTarget = nil
local height = 5
local distance = 2

-- 🎯 กลุ่มพิเศษ
local Special = {
    Thief = {"Thief1","Thief2","Thief3","Thief4","Thief5"},
    Monkey = {"Monkey1","Monkey2","Monkey3","Monkey4","Monkey5"},
    DesertBandit = {"DesertBandit1","DesertBandit2","DesertBandit3","DesertBandit4","DesertBandit5"}
}

-- 🎯 หาเป้า
local function getTarget()
    local targetName = getgenv().Settings.SelectedMonster
    if not targetName then return end

    for _, npc in pairs(npcFolder:GetChildren()) do
        local hum = npc:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            if Special[targetName] then
                if table.find(Special[targetName], npc.Name) then
                    return npc
                end
            else
                if string.find(npc.Name, targetName) then
                    return npc
                end
            end
        end
    end
end

-- 🔥 Auto Farm
RunService.Heartbeat:Connect(function()
    if not getgenv().Settings.AutoFarm or not hrp then return end

    if not currentTarget
    or not currentTarget.Parent
    or not currentTarget:FindFirstChildOfClass("Humanoid")
    or currentTarget:FindFirstChildOfClass("Humanoid").Health <= 0 then
        
        currentTarget = getTarget()
    end

    if currentTarget then
        local head = currentTarget:FindFirstChild("Head")
        if head then
            local targetPos = head.Position + head.CFrame.LookVector * -distance + Vector3.new(0, height, 0)
            hrp.AssemblyLinearVelocity = Vector3.zero
            hrp.AssemblyAngularVelocity = Vector3.zero
            hrp.CFrame = CFrame.lookAt(targetPos, head.Position)
        end
    end
end)

