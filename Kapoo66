local tabs = {
    "Toggle_EnableQuestRepeat",
    "Toggle_AutoQuestRepeat"
}

local path = game:GetService("Players").LocalPlayer.PlayerGui.SettingsUI.MainFrame.Frame.Content.SettingsTabFrame

for _, name in pairs(tabs) do
    local btn = path[name].SettingsHolder.On
    for _, c in pairs(getconnections(btn.Activated)) do
        pcall(function() c.Function() end)
    end
endder.On
