-- monster list
local function getMonsters()

	local t = {}

	for _,v in pairs(npcFolder:GetChildren()) do
		if v:IsA("Model") then
			table.insert(t,v)
		end
	end

	table.sort(t,function(a,b)
		return a.Name:lower() < b.Name:lower()
	end)

	return t

end

local function refresh()

	for _,v in pairs(scroll:GetChildren()) do
		if v:IsA("TextButton") then
			v:Destroy()
		end
	end

	local monsters = getMonsters()

	for _,npc in ipairs(monsters) do

		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1,-4,0,32)
		b.Text = npc.Name
		b.BackgroundColor3 = Color3.fromRGB(60,60,60)
		b.Parent = scroll

		b.MouseButton1Click:Connect(function()

			if selected[npc.Name] then
				selected[npc.Name] = nil
				b.BackgroundColor3 = Color3.fromRGB(60,60,60)
			else
				selected[npc.Name] = true
				b.BackgroundColor3 = Color3.fromRGB(0,170,80)
			end

		end)

	end

	scroll.CanvasSize = UDim2.new(0,0,0,#monsters*34)

end

refresh()

refreshBtn.MouseButton1Click:Connect(refresh)

unselectBtn.MouseButton1Click:Connect(function()

	selected = {}

	for _,v in pairs(scroll:GetChildren()) do
		if v:IsA("TextButton") then
			v.BackgroundColor3 = Color3.fromRGB(60,60,60)
		end
	end

end)

local function getTarget()

	for _,npc in pairs(npcFolder:GetChildren()) do

		if selected[npc.Name] then

			local hum = npc:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				return npc
			end

		end

	end

end

startBtn.MouseButton1Click:Connect(function()
	farming = true
end)

stopBtn.MouseButton1Click:Connect(function()
	farming = false
	currentTarget = nil
end)

RunService.Heartbeat:Connect(function()

	if not farming then return end

	if not currentTarget
	or not currentTarget.Parent
	or currentTarget:FindFirstChildOfClass("Humanoid").Health <= 0 then
		
		currentTarget = getTarget()

	end

	if currentTarget then

		local head = currentTarget:FindFirstChild("Head")

		if head then

			local pos = head.Position + Vector3.new(0,height,2)

			hrp.AssemblyLinearVelocity = Vector3.zero
			hrp.AssemblyAngularVelocity = Vector3.zero

			hrp.CFrame = CFrame.lookAt(pos,head.Position)

			remote:FireServer()

			if skill1 then
				abilityRemote:FireServer(1)
			end

			if skill2 then
				abilityRemote:FireServer(2)
			end

		end

	end

end)
