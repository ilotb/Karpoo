local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")

local npcFolder = workspace:WaitForChild("NPCs")
local RunService = game:GetService("RunService")

local level = player.Data.Level

-- ตารางมอนตามเลเวล
local monsterByLevel = {
	[0] = {"Thief1","Thief2","Thief3","Thief4","Thief5"},
	[110] = {"Monkey1","Monkey2","Monkey3","Monkey4","Monkey5"},
	[300] = {"DesertBandit1","DesertBandit2","DesertBandit3","DesertBandit4","DesertBandit5"},
    [500] = {"DesertBoss"},
	[800] = {"FrostRogue1","FrostRogue2","FrostRogue3","FrostRogue4","FrostRogue5"},
	[1200] = {"SnowBoss"}
}

local selected = {}
local farming = true
local currentTarget = nil
local height = 10


local function updateMonsterList()

	selected = {}

	local chosenLevel = 0

	for reqLevel,_ in pairs(monsterByLevel) do
		if level.Value >= reqLevel and reqLevel >= chosenLevel then
			chosenLevel = reqLevel
		end
	end

	for _,name in pairs(monsterByLevel[chosenLevel]) do
		selected[name] = true
	end

end


updateMonsterList()

level:GetPropertyChangedSignal("Value"):Connect(function()
	updateMonsterList()
end)


local function getTarget()

	for _,npc in pairs(npcFolder:GetChildren()) do
		if selected[npc.Name] then

			local hum = npc:FindFirstChildOfClass("Humanoid")

			if hum and hum.Health > 0 then
				return npc
			end

		end
	end

end


RunService.Heartbeat:Connect(function()

	if not farming then return end

	if not currentTarget
	or not currentTarget.Parent
	or currentTarget:FindFirstChildOfClass("Humanoid").Health <= 0 then
		
		currentTarget = getTarget()

	end

	if currentTarget then

		local head = currentTarget:FindFirstChild("Head")

		if head then

			local pos = head.Position + Vector3.new(0,height,2)

			hrp.AssemblyLinearVelocity = Vector3.zero
			hrp.AssemblyAngularVelocity = Vector3.zero
			hrp.CFrame = CFrame.lookAt(pos, head.Position)

		end
	end

end)
